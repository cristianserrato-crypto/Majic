COMPOSE_PROJECT_NAME=n8n

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-strong-password

N8N_ENCRYPTION_KEY=generate-a-long-random-key
N8N_HOST=example.com
N8N_PORT=5678
N8N_BIND_ADDRESS=0.0.0.0
N8N_PROTOCOL=http
